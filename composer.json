{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "mcardi/mon-chez-moi-server",
    "type": "project",
    "description": "Mon Chez Moi - Laravel API Backend Server",
    "keywords": ["laravel", "framework", "api", "backend"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.31",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "resend/resend-php": "^1.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.1",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.0.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "server/app/",
            "Database\\Factories\\": "server/database/factories/",
            "Database\\Seeders\\": "server/database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "server/tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php server/artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php server/artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('server/.env') || copy('server/.env.example', 'server/.env');\""
        ],
        "post-create-project-cmd": [
            "@php server/artisan key:generate --ansi",
            "@php -r \"file_exists('server/database/database.sqlite') || touch('server/database/database.sqlite');\"",
            "@php server/artisan migrate --graceful --ansi"
        ],
        "deploy": [
            "@php server/artisan config:cache",
            "@php server/artisan route:cache",
            "@php server/artisan view:cache",
            "@php server/artisan optimize"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "lock": false,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "vendor-dir": "server/vendor"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
